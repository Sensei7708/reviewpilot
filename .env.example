# ReviewPilot Configuration
# Copy this to .env and fill in your values

# Ollama configuration
REVIEWPILOT_OLLAMA_HOST=http://127.0.0.1:11434
REVIEWPILOT_MODEL=codellama

# GitHub token (required for posting PR comments)
GITHUB_TOKEN=

# GitLab token (required for posting MR comments)
GITLAB_TOKEN=

# Sales pipeline data directory (optional, defaults to ~/.reviewpilot/sales)
REVIEWPILOT_SALES_DIR=
