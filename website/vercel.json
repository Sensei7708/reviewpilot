{
  "name": "reviewpilot",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/pricing", "dest": "/index.html#pricing" },
    { "src": "/features", "dest": "/index.html#features" },
    { "src": "/faq", "dest": "/index.html#faq" },
    { "src": "/activate", "dest": "/activate.html" }
  ],
  "functions": {
    "api/subscribe.js": {
      "memory": 128
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
