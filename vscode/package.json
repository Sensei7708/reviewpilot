{
  "name": "reviewpilot",
  "displayName": "ReviewPilot",
  "description": "AI-powered code review using Ollama — inline annotations as you code",
  "version": "1.0.0",
  "publisher": "reviewpilot",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "code-review",
    "ai",
    "ollama",
    "linter",
    "review"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reviewpilot.reviewFile",
        "title": "ReviewPilot: Review Current File"
      },
      {
        "command": "reviewpilot.reviewWorkspace",
        "title": "ReviewPilot: Review Workspace Changes"
      },
      {
        "command": "reviewpilot.clearAnnotations",
        "title": "ReviewPilot: Clear Annotations"
      }
    ],
    "configuration": {
      "title": "ReviewPilot",
      "properties": {
        "reviewpilot.model": {
          "type": "string",
          "default": "codellama",
          "description": "Ollama model to use for review"
        },
        "reviewpilot.ollamaHost": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama API host"
        },
        "reviewpilot.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically review files on save"
        }
      }
    }
  }
}
