{
  "name": "reviewpilot",
  "displayName": "ReviewPilot",
  "description": "AI-powered code review using Ollama — private, local, and free. Inline annotations, bug detection, security scanning.",
  "version": "1.2.0",
  "publisher": "reviewpilot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sensei7708/reviewpilot.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other",
    "Testing"
  ],
  "keywords": [
    "code-review",
    "code-reviewer",
    "ai",
    "ai-code-review",
    "ollama",
    "llm",
    "pr-review",
    "pull-request",
    "linter",
    "code-quality",
    "security-scanning",
    "bug-detection",
    "static-analysis",
    "code-analysis",
    "codellama",
    "deepseek",
    "local-ai",
    "private-ai",
    "developer-tool",
    "productivity"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reviewpilot.reviewFile",
        "title": "ReviewPilot: Review Current File"
      },
      {
        "command": "reviewpilot.reviewWorkspace",
        "title": "ReviewPilot: Review Workspace Changes"
      },
      {
        "command": "reviewpilot.clearAnnotations",
        "title": "ReviewPilot: Clear Annotations"
      },
      {
        "command": "reviewpilot.upgrade",
        "title": "ReviewPilot: Upgrade to Pro"
      }
    ],
    "configuration": {
      "title": "ReviewPilot",
      "properties": {
        "reviewpilot.model": {
          "type": "string",
          "default": "codellama",
          "description": "Ollama model to use for review"
        },
        "reviewpilot.ollamaHost": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama API host"
        },
        "reviewpilot.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically review files on save (requires Pro license)"
        },
        "reviewpilot.ignorePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["package-lock.json", "yarn.lock", "pnpm-lock.yaml", "*.min.*"],
          "description": "File patterns to skip during review"
        },
        "reviewpilot.concurrency": {
          "type": "number",
          "default": 3,
          "description": "Number of concurrent review requests"
        },
        "reviewpilot.outputFormat": {
          "type": "string",
          "default": "json",
          "enum": ["json", "text"],
          "description": "Output format for review results"
        },
        "reviewpilot.rules": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["bugs", "security", "performance", "style"],
          "description": "Review rules to apply"
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
