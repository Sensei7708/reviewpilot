{
  "name": "reviewpilot",
  "version": "1.0.0",
  "description": "AI-powered code review CLI. Analyzes PRs and diffs using Ollama (local, free, private).",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "reviewpilot": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dev": "tsc --watch"
  },
  "keywords": [
    "code-review",
    "ai",
    "ollama",
    "pr-review",
    "developer-tool",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/reviewpilot.git"
  },
  "homepage": "https://reviewpilot.dev",
